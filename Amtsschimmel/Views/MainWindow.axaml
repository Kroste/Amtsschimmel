<views:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Amtsschimmel.Views"
        xmlns:vm="using:Amtsschimmel.ViewModels"
        x:Class="Amtsschimmel.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Amtsschimmel — Das Behörden-Incremental"
        Width="1100" Height="756"
        MinWidth="900" MinHeight="620">

    <Window.Styles>
        <!-- Stempel-Button: kurzes Eindrücken beim Klick -->
        <Style Selector="Button.stamp">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.08" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.stamp:pressed">
            <Setter Property="RenderTransform" Value="scale(0.94)" />
        </Style>

        <!-- Toast: gleitet von unten ein und verblasst wieder -->
        <Style Selector="Border.toast">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="translateY(16px)" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"
                                                   Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.toast.visible">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(0px)" />
        </Style>

        <!-- Reform-Button pulsiert, wenn eine Reform bereit ist.
             Wichtig: Keyframe-Animationen haben KEINEN Animator für RenderTransform
             (wirft "No animator registered" zur Laufzeit) — stattdessen die
             Transform-Unterproperties ScaleTransform.ScaleX/ScaleY animieren. -->
        <Style Selector="Button.reform-btn.ready">
            <Style.Animations>
                <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1.04" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1.04" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Goldenes Formular: auffälliges Pulsieren -->
        <Style Selector="Button.golden">
            <Style.Animations>
                <Animation Duration="0:0:0.8" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1.12" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1.12" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <Border Background="#1A1D21">
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Eigene Titelleiste (Projektstandard, siehe DTM/Checkmk) -->
        <Border Grid.Row="0" Background="#2D2D30" Height="36"
                PointerPressed="OnTitleBarPointerPressed"
                DoubleTapped="OnTitleBarDoubleTapped">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="🏛️" VerticalAlignment="Center" />
                    <TextBlock Text="Amtsschimmel — Das Behörden-Incremental"
                               VerticalAlignment="Center" Foreground="White" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="⚙" Command="{Binding ShowSettingsCommand}"
                            Background="Transparent" BorderThickness="0" Width="42" Height="36"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            ToolTip.Tip="Einstellungen" />
                    <Button Content="ⓘ Info" Command="{Binding ShowInfoCommand}"
                            Background="Transparent" BorderThickness="0" Height="36"
                            VerticalContentAlignment="Center" />
                    <Button Content="—" Command="{Binding MinimizeCommand}"
                            Background="Transparent" BorderThickness="0" Width="42" Height="36"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                    <Button Content="☐" Command="{Binding MaximizeCommand}"
                            Background="Transparent" BorderThickness="0" Width="42" Height="36"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                    <Button Content="✕" Command="{Binding CloseCommand}"
                            Background="Transparent" BorderThickness="0" Width="42" Height="36"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="12">

        <!-- Offline-Fortschritt-Banner -->
        <Border Grid.Row="0" IsVisible="{Binding IsOfflineReportVisible}"
                Background="#1E3A5F" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="OK" Command="{Binding DismissOfflineReportCommand}" />
                <TextBlock Text="{Binding OfflineReportText}" TextWrapping="Wrap" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="320,12,*">

            <!-- Linke Spalte: Stempeln + Upgrades -->
            <Border Grid.Column="0" Background="#22262B" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="🏛️ Dein Amt" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />

                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding StempelText}" FontSize="34" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Stempel" Opacity="0.7" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding PerSecondText}" Opacity="0.7" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding AutoClickText}" Opacity="0.7" FontSize="12"
                                   HorizontalAlignment="Center" IsVisible="{Binding IsAutoClickVisible}" />
                        <TextBlock Text="{Binding BuffText}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#E0B14C" HorizontalAlignment="Center"
                                   IsVisible="{Binding IsBuffVisible}" />
                    </StackPanel>

                    <Panel>
                        <Button Classes="stamp" Command="{Binding StampCommand}" Click="OnStampClick"
                                HorizontalAlignment="Stretch" Height="110"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Background="#3A6EA5" CornerRadius="10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="📋 STEMPELN" FontSize="22" FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                                <TextBlock HorizontalAlignment="Center" Opacity="0.85">
                                    <Run Text="+" /><Run Text="{Binding ClickPowerText}" /><Run Text=" pro Klick" />
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Canvas Name="ClickParticleCanvas" IsHitTestVisible="False" ClipToBounds="False" />
                    </Panel>

                    <Border Background="#2A2F35" CornerRadius="6" Padding="10">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold">
                                <Run Text="🖊️ Stempelkissen (Stufe " /><Run Text="{Binding ClickUpgradeLevel}" /><Run Text=")" />
                            </TextBlock>
                            <TextBlock Text="Verdoppelt die Klickkraft." Opacity="0.7" FontSize="12" />
                            <Button Command="{Binding BuyClickUpgradeCommand}"
                                    IsEnabled="{Binding CanBuyClickUpgrade}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                <TextBlock>
                                    <Run Text="Upgrade — " /><Run Text="{Binding ClickUpgradeCostText}" />
                                </TextBlock>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Background="#2A2F35" CornerRadius="6" Padding="10">
                        <StackPanel Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="Boni" />
                            <TextBlock FontSize="12" Opacity="0.8">
                                <Run Text="Paragraphen: " /><Run Text="{Binding Paragraphen}" /><Run Text=" § (je +5 %)" />
                            </TextBlock>
                            <TextBlock FontSize="12" Opacity="0.8">
                                <Run Text="Erfolge: " /><Run Text="{Binding AchievementCountText}" /><Run Text=" (je +1 %)" />
                            </TextBlock>
                            <TextBlock FontSize="12" Opacity="0.8">
                                <Run Text="Gesamt-Multiplikator: " /><Run Text="{Binding GlobalMultiplierText}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Rechte Spalte: Tabs -->
            <TabControl Grid.Column="2" Name="MainTabs">

                <TabItem Header="🏢 Personal">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Generators}" Margin="0,8,8,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GeneratorViewModel">
                                    <Border Background="#22262B" CornerRadius="8" Padding="12" Margin="0,0,0,8"
                                            IsVisible="{Binding IsVisible}">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock FontWeight="Bold" FontSize="15">
                                                    <Run Text="{Binding Name}" />
                                                    <Run Text=" × " /><Run Text="{Binding Owned}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding Description}" Opacity="0.65" FontSize="12"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Opacity="0.8" FontSize="12">
                                                    <Run Text="Produziert " /><Run Text="{Binding ProductionText}" />
                                                    <Run Text="  " /><Run Text="{Binding MilestoneText}" Foreground="#E0B14C" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding ReformLockText}" FontSize="12"
                                                           Foreground="#E0B14C" IsVisible="{Binding IsReformLocked}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="6" MinWidth="200">
                                                <Button Command="{Binding BuyCommand}" IsEnabled="{Binding CanBuy}"
                                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                                    <TextBlock>
                                                        <Run Text="Kaufen — " /><Run Text="{Binding CostText}" />
                                                    </TextBlock>
                                                </Button>
                                                <Button Command="{Binding Buy10Command}" IsEnabled="{Binding CanBuy10}"
                                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                                    <TextBlock>
                                                        <Run Text="×10 — " /><Run Text="{Binding Cost10Text}" />
                                                    </TextBlock>
                                                </Button>
                                                <Button Command="{Binding BuyAutoBuyerCommand}"
                                                        IsEnabled="{Binding CanBuyAutoBuyer}"
                                                        IsVisible="{Binding !AutoBuyerOwned}"
                                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                                    <TextBlock FontSize="12">
                                                        <Run Text="🤖 Auto-Buyer — " /><Run Text="{Binding AutoBuyerCostText}" />
                                                    </TextBlock>
                                                </Button>
                                                <ToggleSwitch IsChecked="{Binding AutoBuyerEnabled}"
                                                              IsVisible="{Binding AutoBuyerOwned}"
                                                              OnContent="Auto-Kauf an" OffContent="Auto-Kauf aus"
                                                              HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="📚 Akademie">
                    <ScrollViewer>
                        <StackPanel Margin="0,8,8,0">
                            <TextBlock Margin="4,0,0,8" Opacity="0.7" FontSize="12" TextWrapping="Wrap">
                                <Run Text="Verwaltungsakademie — Fortbildungen verbessern dein Amt, viele sind mehrstufig ausbaubar. Alles verfällt bei einer Reform. Stand: " /><Run Text="{Binding ResearchCountText}" />
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding Research}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ResearchViewModel">
                                        <Border Background="#22262B" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="✅" IsVisible="{Binding IsMaxed}" />
                                                        <TextBlock Text="🔒" IsVisible="{Binding IsLocked}" Opacity="0.6" />
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" />
                                                        <TextBlock Text="{Binding LevelText}" FontSize="12" Opacity="0.7"
                                                                   VerticalAlignment="Center" Foreground="#E0B14C" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}" Opacity="0.65" FontSize="12"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding EffectText}" FontSize="12"
                                                               Foreground="#7EC8A4" />
                                                    <TextBlock Text="{Binding PrerequisiteText}" FontSize="11"
                                                               Opacity="0.55" IsVisible="{Binding HasPrerequisites}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="180">
                                                    <Button Command="{Binding BuyCommand}" IsEnabled="{Binding CanResearch}"
                                                            IsVisible="{Binding !IsMaxed}"
                                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                                        <TextBlock>
                                                            <Run Text="Fortbilden — " /><Run Text="{Binding CostText}" />
                                                        </TextBlock>
                                                    </Button>
                                                    <TextBlock Text="Maximalstufe" IsVisible="{Binding IsMaxed}"
                                                               Opacity="0.6" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="📜 Reform">
                    <StackPanel Spacing="16" Margin="16" MaxWidth="560" HorizontalAlignment="Left">
                        <TextBlock Text="Verwaltungsreform" FontSize="22" FontWeight="Bold" />
                        <TextBlock TextWrapping="Wrap" Opacity="0.85">
                            Eine Verwaltungsreform setzt dein Amt komplett zurück: Stempel, Personal,
                            Klick-Upgrades und alle Fortbildungen der Akademie gehen verloren. Dafür
                            erhältst du Paragraphen — jeder Paragraph steigert deine Produktion dauerhaft
                            um 5 %. Gekaufte Auto-Buyer und Erfolge überstehen jede Reform.
                        </TextBlock>
                        <Border Background="#22262B" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding PrestigeProgressText}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding NextThresholdText}" FontSize="12" Opacity="0.7"
                                           TextWrapping="Wrap" />
                                <TextBlock FontSize="12" Opacity="0.7">
                                    <Run Text="Bisherige Reformen: " /><Run Text="{Binding TotalReformen}" />
                                    <Run Text="   |   Paragraphen: " /><Run Text="{Binding Paragraphen}" /><Run Text=" §" />
                                </TextBlock>
                                <ProgressBar Minimum="0" Maximum="1" Value="{Binding PrestigeProgress}"
                                             Height="10" CornerRadius="5" Foreground="#E0B14C" />
                                <Button Classes="reform-btn" Classes.ready="{Binding CanPrestige}"
                                        Command="{Binding PrestigeCommand}" IsEnabled="{Binding CanPrestige}"
                                        Background="#8B4513" Height="48"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                    <TextBlock FontWeight="Bold">
                                        <Run Text="📜 Reform durchführen (+" /><Run Text="{Binding PendingParagraphen}" /><Run Text=" §)" />
                                    </TextBlock>
                                </Button>
                            </StackPanel>
                        </Border>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.6">
                            Formel: Paragraphen = ⌊√(verdiente Stempel / Schwelle)⌋ — die Schwelle
                            verzehnfacht sich mit jeder Reform. Manche Generatoren und Fortbildungen
                            (u. a. Bundesministerium, KI-Cloud, Stempelautomat, Exzellenz-Zweig)
                            schalten erst nach bestimmten Reformen frei.
                        </TextBlock>

                        <Border Background="#2E2712" CornerRadius="8" Padding="16"
                                BorderBrush="#E0B14C" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="🏆 Verwaltungsvollendung" FontSize="18" FontWeight="Bold"
                                           Foreground="#E0B14C" />
                                <TextBlock TextWrapping="Wrap" Opacity="0.85" FontSize="12"
                                           Text="Das finale Ziel: der Goldene Aktendeckel. Wer ihn erwirbt, hat das Amt vollendet — gespielt werden darf danach trotzdem weiter." />
                                <StackPanel Spacing="4" IsVisible="{Binding !HasWon}">
                                    <TextBlock Text="{Binding VictoryResearchText}" FontSize="13" />
                                    <TextBlock Text="{Binding VictoryReformText}" FontSize="13" />
                                    <TextBlock Text="{Binding VictoryCostText}" FontSize="13" />
                                </StackPanel>
                                <Button Content="🏆 Goldenen Aktendeckel erwerben"
                                        Command="{Binding BuyVictoryCommand}" IsEnabled="{Binding CanWin}"
                                        IsVisible="{Binding !HasWon}"
                                        Background="#8B6914" Height="44" FontWeight="Bold"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                <TextBlock Text="{Binding VictoryWonText}" TextWrapping="Wrap"
                                           IsVisible="{Binding HasWon}" Foreground="#E0B14C" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <TabItem Header="🏆 Erfolge">
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Achievements}" Margin="0,8,8,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AchievementViewModel">
                                    <Border Background="#22262B" CornerRadius="8" Padding="12" Margin="0,0,0,6">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left" Width="36" FontSize="20"
                                                       Text="{Binding IsUnlocked, Converter={x:Static vm:Converters.UnlockIcon}}" />
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" />
                                                <TextBlock Text="{Binding DisplayDescription}" Opacity="0.65" FontSize="12" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="📈 Statistik">
                    <ScrollViewer>
                        <StackPanel Margin="16" Spacing="14" MaxWidth="640" HorizontalAlignment="Left">
                            <TextBlock Text="Amtsstatistik" FontSize="22" FontWeight="Bold" />
                            <Border Background="#22262B" CornerRadius="8" Padding="16">
                                <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Spielzeit gesamt" Opacity="0.7" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding StatPlayTime}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Stempel (alle Zeiten)" Opacity="0.7" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StatAllTimeEarned}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Stempel (dieser Run)" Opacity="0.7" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding StatRunEarned}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Manuelle Klicks" Opacity="0.7" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding StatClicks}" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Rekord-Einkommen" Opacity="0.7" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding StatHighestIncome}" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Reformen / Paragraphen" Opacity="0.7" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding StatReformen}" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Goldene Formulare" Opacity="0.7" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding StatGolden}" />
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Personal gesamt" Opacity="0.7" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding StatPersonal}" />
                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Fortbildungen" Opacity="0.7" />
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding StatResearch}" />
                                </Grid>
                            </Border>
                            <Border Background="#22262B" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Einkommen/s (letzte 5 Minuten)" Opacity="0.7" FontSize="12" />
                                    <Border Height="74" ClipToBounds="True">
                                        <Polyline Points="{Binding SparklinePoints}" Stroke="#7EC8A4"
                                                  StrokeThickness="2" StrokeJoin="Round" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
        <!-- Goldenes Formular: Overlay über dem Inhalt, Position setzt der Code-Behind -->
        <Canvas Grid.Row="1" Name="GoldenCanvas" ZIndex="9" ClipToBounds="True">
            <Button Name="GoldenFormButton" Classes="golden"
                    IsVisible="{Binding IsGoldenFormVisible}"
                    Command="{Binding ClickGoldenFormCommand}"
                    Background="#B8860B" CornerRadius="10" Padding="10,6"
                    Content="📄✨" FontSize="24"
                    ToolTip.Tip="Goldenes Formular — schnell abstempeln!" />
        </Canvas>

        <!-- Achievement-/Reform-Toast als Overlay (verschiebt das Layout nicht) -->
        <Border Grid.Row="1" Classes="toast" Classes.visible="{Binding IsToastVisible}"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,20" MaxWidth="640" ZIndex="10"
                Background="#2D5016" CornerRadius="8" Padding="14,10"
                BoxShadow="0 4 16 0 #66000000">
            <TextBlock Text="{Binding ToastText}" TextWrapping="Wrap" FontWeight="SemiBold" />
        </Border>
    </Grid>

        <!-- Statuszeile: Amtsblatt-Ticker + Speicher-Indikator -->
        <Border Grid.Row="2" Background="#22262B" Padding="12,5">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="📰 Amtsblatt: " Opacity="0.6" FontSize="12" />
                <TextBlock Grid.Column="1" Text="{Binding TickerText}" FontSize="12" Opacity="0.85"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Text="{Binding SaveIndicatorText}" FontSize="12"
                           Opacity="0.5" Margin="12,0,0,0" />
            </Grid>
        </Border>
    </Grid>
    </Border>
</views:ChromeWindow>
